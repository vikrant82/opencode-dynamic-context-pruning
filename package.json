{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@vikrant82/opencode-dcp",
    "version": "3.3.1",
    "type": "module",
    "description": "OpenCode plugin that optimizes token usage by pruning obsolete tool outputs from conversation context",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./tui": {
            "types": "./dist/tui.d.ts",
            "import": "./tui.tsx"
        }
    },
    "scripts": {
        "clean": "rm -rf dist",
        "build": "npm run clean && tsup && tsc --emitDeclarationOnly",
        "verify:package": "node scripts/verify-package.mjs",
        "check:package": "npm run build && npm run verify:package",
        "prepublishOnly": "npm run check:package",
        "dev": "opencode plugin dev",
        "typecheck": "tsc --noEmit",
        "test": "node --import tsx --test tests/*.test.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "dcp": "tsx scripts/print.ts"
    },
    "keywords": [
        "opencode",
        "opencode-plugin",
        "plugin",
        "context",
        "pruning",
        "optimization",
        "tokens"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vikrant82/opencode-dynamic-context-pruning.git"
    },
    "bugs": {
        "url": "https://github.com/vikrant82/opencode-dynamic-context-pruning/issues"
    },
    "homepage": "https://github.com/vikrant82/opencode-dynamic-context-pruning#readme",
    "author": "tarquinen",
    "license": "AGPL-3.0-or-later",
    "peerDependencies": {
        "@opencode-ai/plugin": ">=1.4.3",
        "@opentui/core": "^0.4.2",
        "@opentui/solid": "^0.4.2",
        "solid-js": "^1.9.12"
    },
    "dependencies": {
        "@anthropic-ai/tokenizer": "^0.0.4",
        "@opencode-ai/sdk": "^1.4.3",
        "jsonc-parser": "^3.3.1"
    },
    "devDependencies": {
        "@opencode-ai/plugin": "^1.4.3",
        "@opentui/core": "^0.4.2",
        "@opentui/solid": "^0.4.2",
        "@types/node": "^25.5.0",
        "prettier": "^3.8.1",
        "solid-js": "^1.9.12",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    },
    "overrides": {
        "@babel/core": "7.29.7",
        "esbuild": "0.28.1"
    },
    "files": [
        "dist/",
        "lib/",
        "tui.tsx",
        "README.md",
        "LICENSE"
    ]
}
